# ================================================================
#  db-migrate — Environment Configuration
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ================================================================


# ── LOCAL DOCKER ─────────────────────────────────────────────────
# Name of your local MySQL 8 Docker container
DOCKER_CONTAINER=mysql8


# ── BACKUP STORAGE ───────────────────────────────────────────────
# Where compressed backup files are stored on your Mac
# Default: ~/mysql_backups (auto-created if not exists)
BACKUP_DIR=~/mysql_backups


# ── SOURCE SERVER A (Germany) ────────────────────────────────────
SRC_SSH_USER=ubuntu
SRC_SSH_HOST=server-a.example.com
SRC_SSH_PORT=22
SRC_SSH_KEY=~/.ssh/id_rsa

SRC_DB_HOST=127.0.0.1
SRC_DB_PORT=3306
SRC_DB_USER=root
SRC_DB_PASS=your_source_db_password
SRC_DB_NAME=your_source_database

# Local port to bind the SSH tunnel for Source (must be free)
SRC_LOCAL_PORT=13306


# ── DESTINATION SERVER B (Malaysia) ──────────────────────────────
DST_SSH_USER=ubuntu
DST_SSH_HOST=server-b.example.com
DST_SSH_PORT=22
DST_SSH_KEY=~/.ssh/id_rsa

DST_DB_HOST=127.0.0.1
DST_DB_PORT=3306
DST_DB_USER=root
DST_DB_PASS=your_destination_db_password

# Local port to bind the SSH tunnel for Destination (must be free)
DST_LOCAL_PORT=13307


# ── DESTINATION DATABASE NAMING ───────────────────────────────────
# Final DB name = DB_PREFIX + _ + auto-generated timestamp suffix
# Example: restore_20250315_143022
DB_PREFIX=restore


# ── TABLES CONFIGURATION ──────────────────────────────────────────
# Path to the file listing tables to backup WITH data
# All other tables will receive schema only
# Relative to project root or absolute path
TABLES_FILE=./config/tables.conf


# ── DUMP OPTIONS ──────────────────────────────────────────────────
# Include stored routines (procedures & functions) — true/false
DUMP_ROUTINES=true

# Include triggers — true/false
DUMP_TRIGGERS=true

# Include events — true/false
DUMP_EVENTS=true

# Compress backup file — true/false
COMPRESS_BACKUP=true
